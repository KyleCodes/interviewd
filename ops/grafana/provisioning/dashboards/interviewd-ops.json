{
  "uid": "interviewd-ops",
  "title": "Interviewd Ops",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "interviewd",
    "autoscaling"
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": {
          "label": "compose_service",
          "type": 1
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Queue depth",
      "description": "Jobs waiting in the queue right now; anything persistently above the yellow band means workers are not keeping up.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "autoscaler_queue_depth",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 200
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Oldest job age",
      "description": "Age of the oldest unprocessed job; this is the user-facing wait time, and red means SLO-relevant backlog.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "autoscaler_oldest_job_seconds",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 15
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "API p95",
      "description": "API p95 latency as seen by the autoscaler; sustained yellow/red indicates the API tier needs more replicas or is blocked downstream.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "autoscaler_api_p95_ms",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Running replicas",
      "description": "Current replica count per scaled service; compare against the replicas-over-time panel to confirm the autoscaler's view matches reality.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "autoscaler_current_replicas{service=\"api\"}",
          "legendFormat": "api",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "expr": "autoscaler_current_replicas{service=\"worker\"}",
          "legendFormat": "worker",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Replicas over time (desired vs current)",
      "description": "Desired stepping up while current lags shows scaling in flight; desired pinned at its cap with queue depth still climbing means the autoscaler is at max.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "autoscaler_current_replicas{service=\"api\"}",
          "legendFormat": "api current",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "expr": "autoscaler_desired_replicas{service=\"api\"}",
          "legendFormat": "api desired",
          "instant": false,
          "range": true
        },
        {
          "refId": "C",
          "expr": "autoscaler_current_replicas{service=\"worker\"}",
          "legendFormat": "worker current",
          "instant": false,
          "range": true
        },
        {
          "refId": "D",
          "expr": "autoscaler_desired_replicas{service=\"worker\"}",
          "legendFormat": "worker desired",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Queue depth & oldest age",
      "description": "Climbing depth with flat replicas = autoscaler at max; oldest age falling back toward zero after a spike confirms the backlog is draining.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "autoscaler_queue_depth",
          "legendFormat": "queue depth",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "expr": "autoscaler_oldest_job_seconds",
          "legendFormat": "oldest job age",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "oldest job age"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API latency percentiles",
      "description": "p50 flat while p95/p99 climb points to queuing or a slow dependency rather than uniformly slow requests.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(api_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "instant": false,
          "range": true
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(api_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Throughput: enqueued vs processed /s",
      "description": "Enqueued sustained above processed while workers sit at max replicas = the system is saturated and the queue will grow without bound. Offered-load line = traffic dial (80% of it is enqueues); a persistent gap above processed/s at max workers is saturation.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(api_jobs_enqueued_total[1m]))",
          "legendFormat": "enqueued/s",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "expr": "sum(rate(worker_jobs_processed_total[1m]))",
          "legendFormat": "processed/s",
          "instant": false,
          "range": true
        },
        {
          "refId": "C",
          "expr": "traffic_target_rps * 0.8",
          "legendFormat": "offered enqueue/s (dial)",
          "range": true,
          "instant": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Worker saturation (busy fraction)",
      "description": "Fraction of live workers currently busy; pinned above 0.8 is the signal to scale, pinned at 1.0 at max replicas means adding load only grows the queue.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(worker_busy) / count(up{job=\"worker\"} == 1)",
          "legendFormat": "busy fraction",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.8
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Cache hit ratio",
      "description": "A falling hit ratio under load means more requests reach postgres, which shows up as rising API latency before anything else breaks.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(api_cache_hits_total[1m])) / sum(rate(api_cache_requests_total[1m]))",
          "legendFormat": "hit ratio",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP status rates",
      "description": "Per-status request rate; a rising 5xx band during scale-up points at replica churn or an overloaded dependency, not client behavior.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(api_request_duration_seconds_count[1m]))",
          "legendFormat": "{{status}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Scale events",
      "description": "Scale decisions per minute by service and direction; rapid alternating up/down bars indicate flapping and an autoscaler cooldown that is too short.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service,direction) (increase(autoscaler_scale_events_total[1m]))",
          "legendFormat": "{{service}} {{direction}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 60,
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 13,
      "type": "logs",
      "title": "Service logs",
      "description": "Live logs for the selected services; correlate error bursts here with scale events and status-rate spikes above to find the causing component.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=~\"$service\"}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}